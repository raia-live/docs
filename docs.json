{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "SenseLab",
  "colors": {
    "primary": "#3b82f6",
    "light": "#93c5fd",
    "dark": "#2563eb",
    "background": {
      "dark": "#07090f",
      "light": "#ffffff"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://www.sense-lab.ai",
          "icon": "globe"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@sense-lab.ai",
          "icon": "envelope"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/senselab-logo.png",
    "dark": "/logo/senselab-logo.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://www.sense-lab.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://app.raia.live"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/senselab",
      "github": "https://github.com/senselab",
      "linkedin": "https://linkedin.com/company/sense-lab"
    }
  }
}
